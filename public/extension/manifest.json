{
  "manifest_version": 2,
  "name": "J'cOLorE le texte",
  "version": "2.1.0",
  "description": "Extension Firefox pour faciliter la lecture des syllabes et des sons",
  "author": "Chêne Denis",
  "homepage_url": "https://colore-texte.lovable.app",
  "permissions": ["activeTab", "<all_urls>", "storage"],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "browser_action": {
    "default_icon": {
      "48": "icon.png",
      "128": "icon.png"
    },
    "default_title": "J'cOLorE le texte",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "commands": {
    "toggle-colore": {
      "suggested_key": {
        "default": "Ctrl+Shift+J"
      },
      "description": "Activer/désactiver J'cOLorE le texte"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "lirecouleur.js",
        "functionlc6.js",
        "processlc6.js",
        "json_default_profile.js",
        "userprofile.js",
        "content.js"
      ],
      "css": ["colore.css"]
    }
  ],
  "icons": {
    "48": "icon.png",
    "128": "icon.png"
  }
}
